<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Selected -->
    <item android:state_selected="true">
        <shape android:shape="oval">
            <solid android:color="#66BB6A"/>
            <stroke
                android:width="3dp"
                android:color="#FFFFFF"/>
        </shape>
    </item>

    <!-- Default -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#66BB6A"/>
        </shape>
    </item>

</selector>