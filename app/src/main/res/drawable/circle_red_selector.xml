<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- khi được chọn -->
    <item android:state_selected="true">
        <shape android:shape="oval">
            <solid android:color="#FF5252"/>
            <stroke
                android:width="3dp"
                android:color="#FFFFFF"/>
        </shape>
    </item>

    <!-- mặc định -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#FF5252"/>
        </shape>
    </item>

</selector>