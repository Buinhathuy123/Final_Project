<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6F8">

    <ScrollView
        android:id="@+id/r2vguwhk65qw"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">


            <!-- TITLE -->
            <TextView
                android:id="@+id/rogr88iz4na"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hãy chọn mức độ phù hợp của mỗi câu với bản thân bạn."
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2E3148"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="30dp"
                android:gravity="center"/>


            <!-- PROGRESS BAR -->
            <LinearLayout
                android:id="@+id/fulltiendo"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:background="#DDE3EA"
                android:layout_marginBottom="6dp">

                <View
                    android:id="@+id/thanhtiendo"
                    android:layout_width="40dp"
                    android:layout_height="match_parent"
                    android:background="#22A06B"/>
            </LinearLayout>


            <TextView
                android:id="@+id/texttiendo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bước 1 / 20"
                android:textSize="14sp"
                android:textColor="#7B8194"
                android:layout_marginBottom="40dp"/>


            <!-- QUESTION -->
            <TextView
                android:id="@+id/textCauHoi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tôi luôn cố gắng đạt được sự chính xác và cẩn thận trong mọi công việc."
                android:textSize="18sp"
                android:textColor="#2E3148"
                android:gravity="center"
                android:layout_marginBottom="40dp"/>


            <!-- ANSWERS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">


                <!-- Hoàn toàn không đồng ý -->
                <LinearLayout
                    android:id="@+id/btnanswer1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/rfhcopeyua74"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/circle_gray_selector"/>

                    <TextView
                        android:id="@+id/rkfgxuhfnj"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hoàn toàn\nkhông đồng ý"
                        android:textSize="14sp"
                        android:textColor="#2E3148"
                        android:gravity="center"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>


                <!-- Không đồng ý -->
                <LinearLayout
                    android:id="@+id/btnanswer2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/rn2sqq8hs6s"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/circle_green_selector"/>

                    <TextView
                        android:id="@+id/ri1layallfa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Không đồng ý"
                        android:textSize="14sp"
                        android:textColor="#2E3148"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>


                <!-- Trung lập -->
                <LinearLayout
                    android:id="@+id/btnanswer3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/r2h3dli005i"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/circle_orange_selector"/>

                    <TextView
                        android:id="@+id/rml03nipvo3c"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trung lập"
                        android:textSize="14sp"
                        android:textColor="#2E3148"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>


                <!-- Đồng ý -->
                <LinearLayout
                    android:id="@+id/btnanswer4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/r1y9q5zgzvp4"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/circle_red_selector"/>

                    <TextView
                        android:id="@+id/rsxnewt2ggn9"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đồng ý"
                        android:textSize="14sp"
                        android:textColor="#2E3148"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

            </LinearLayout>


            <!-- NEXT BUTTON -->
            <LinearLayout
                android:id="@+id/btnNext"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="#22A06B"
                android:gravity="center"
                android:layout_marginTop="50dp"
                android:layout_marginBottom="30dp">

                <TextView
                    android:id="@+id/rtkkpi163dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tiếp theo"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>