<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:orientation="vertical">

    <!-- Header: Nút Back + Tiêu đề -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_circle"
            android:clickable="true"
            android:focusable="true"
            android:padding="10dp"
            android:src="@drawable/outline_arrow_back_24"
            app:tint="#1E293B" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Chi tiết kết quả"
            android:textColor="#1E293B"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Card hiển thị Điểm tổng quát, Mức độ và Ngày tháng -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <TextView
                        android:id="@+id/txtDetailTotalScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#1E293B"
                        android:textSize="56sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtDetailLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Mức độ: --"
                        android:textColor="#64748B"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtDetailFullDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Ngày thực hiện: --/--/----"
                        android:textColor="#94A3B8"
                        android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHI TIẾT THÀNH PHẦN"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"
                android:letterSpacing="0.1"/>

            <!-- Mục Trắc nghiệm -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_detail_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/text" app:tint="#4C6FFF" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:text="Trắc nghiệm (PHQ-9)" android:textColor="#64748B" android:textSize="14sp" />
                <TextView android:id="@+id/txtDetailQuiz" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-- / 24" android:textColor="#1E293B" android:textSize="16sp" android:textStyle="bold" />
            </LinearLayout>

            <!-- Mục Giọng nói -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_detail_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/image" app:tint="#22A06B" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:text="Phân tích giọng nói" android:textColor="#64748B" android:textSize="14sp" />
                <TextView android:id="@+id/txtDetailVoice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bình thường" android:textColor="#1E293B" android:textSize="16sp" android:textStyle="bold" />
            </LinearLayout>

            <!-- Mục Hình ảnh -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_detail_item"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/image" app:tint="#F59E0B" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:text="Phân tích khuôn mặt" android:textColor="#64748B" android:textSize="14sp" />
                <TextView android:id="@+id/txtDetailFace" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bình thường" android:textColor="#1E293B" android:textSize="16sp" android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>