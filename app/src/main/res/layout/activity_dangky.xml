<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F8FB">

    <!-- MAIN -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:orientation="vertical">

            <!-- BACK -->
            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/back"
                android:layout_marginBottom="20dp"/>

            <!-- TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tạo tài khoản"
                android:textColor="#333333"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginBottom="30dp"/>

            <!-- FORM -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/result_card"
                android:padding="20dp"
                android:orientation="vertical">

                <!-- USERNAME -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tên người dùng"
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/user_name"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/input_square"
                    android:padding="12dp"
                    android:hint="Nhập tên người dùng"
                    android:textColor="#333333"/>

                <!-- PASSWORD -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mật khẩu"
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="6dp"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp">

                    <EditText
                        android:id="@+id/user_password"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/input_square"
                        android:padding="12dp"
                        android:paddingEnd="45dp"
                        android:hint="Nhập mật khẩu"
                        android:inputType="textPassword"
                        android:textColor="#333333"/>

                    <ImageView
                        android:id="@+id/toggle_password"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/hidepass"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="12dp"/>
                </RelativeLayout>

                <!-- CONFIRM -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xác nhận mật khẩu"
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="6dp"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp">

                    <EditText
                        android:id="@+id/user_confirm_password"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/input_square"
                        android:padding="12dp"
                        android:paddingEnd="45dp"
                        android:hint="Nhập lại mật khẩu"
                        android:inputType="textPassword"
                        android:textColor="#333333"/>

                    <ImageView
                        android:id="@+id/toggle_confirm_password"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/hidepass"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="12dp"/>
                </RelativeLayout>

                <!-- EMAIL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="#555555"
                    android:textSize="14sp"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/user_email"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/input_square"
                    android:padding="12dp"
                    android:hint="Nhập email"
                    android:inputType="textEmailAddress"
                    android:textColor="#333333"/>

            </LinearLayout>

            <!-- BUTTON -->
            <LinearLayout
                android:id="@+id/btn_register"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="30dp"
                android:background="@drawable/button_start"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đăng ký"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- OTP POPUP -->
    <LinearLayout
        android:id="@+id/layoutOtp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:background="#80000000"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/result_card">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nhập mã OTP"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp">

                <EditText android:id="@+id/otp1" style="@style/style1"/>
                <EditText android:id="@+id/otp2" style="@style/style1"/>
                <EditText android:id="@+id/otp3" style="@style/style1"/>
                <EditText android:id="@+id/otp4" style="@style/style1"/>
                <EditText android:id="@+id/otp5" style="@style/style1"/>
                <EditText android:id="@+id/otp6" style="@style/style1"/>

            </LinearLayout>

            <TextView
                android:id="@+id/txtResend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gửi lại sau 30s"
                android:layout_marginTop="10dp"/>

            <LinearLayout
                android:id="@+id/btnVerify"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/button_start"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xác nhận"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</FrameLayout>