<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <ScrollView
        android:id="@+id/rgskdb8ru1sg"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="30dp">

            <LinearLayout
                android:id="@+id/rci7iah53sdo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="19dp"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/ry180wze2yl"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/avatar" />
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />
                <ImageView
                    android:id="@+id/rf3ouh89ln34"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/chuong" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/r5ghgjed8u94"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="25dp"
                android:layout_marginEnd="11dp"
                android:layout_marginBottom="40dp"
                android:orientation="horizontal">
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/r99b066ir108"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:scaleType="fitXY"
                    android:src="@drawable/back"
                    app:shapeAppearanceOverlay="@style/cr40" />
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/rtp2vhz88lo"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:scaleType="fitXY"
                    android:src="@drawable/menu"
                    app:shapeAppearanceOverlay="@style/cr40" />
            </LinearLayout>

            <TextView
                android:id="@+id/rnhzr1j5nchl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="31dp"
                android:layout_marginBottom="30dp"
                android:text="Kết quả đánh giá bằng\nhình ảnh"
                android:textColor="#4A4A4A"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rxkmwbhgwgz"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="31dp"
                android:layout_marginBottom="12dp"
                android:text="Trầm cảm trung bình"
                android:textColor="#4A4A4A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/rrk64zpie7uj"
                android:layout_width="293dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="31dp"
                android:layout_marginBottom="40dp"
                android:text="Bạn nên trò chuyện với bác sĩ hoặc chuyên gia sức khoẻ tâm thần"
                android:textColor="#4A4A4A"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/r2ttsw0qj99o"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="30dp"
                android:text="🎧 Xem đề xuất bộ âm nhạc dành cho bạn"
                android:textColor="#C28989"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtGoiY"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="31dp"
                android:layout_marginBottom="15dp"
                android:gravity="center"
                android:text="✨ Gợi ý: Hãy làm thêm bài Trắc nghiệm để có kết quả chính xác nhất"
                android:textColor="#22A06B"
                android:textSize="14sp"
                android:textStyle="italic"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/btnGoToQuiz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="43dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/button_secondary"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Làm bài Trắc nghiệm ➔"
                    android:textColor="#4C6FFF"
                    android:textSize="17sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/raf9m3etc9f6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="43dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/cr20b7fa7b5"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingVertical="13dp">
                <TextView
                    android:id="@+id/r88l0y11onat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Về Trang Chủ"
                    android:textColor="#4A4A4A"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>