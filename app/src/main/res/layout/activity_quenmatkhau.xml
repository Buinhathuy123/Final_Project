<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#F6F8FB"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ================= MAIN UI ================= -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- BACK -->
            <ImageView
                android:id="@+id/r36h1tttdukv"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/back"
                android:scaleType="fitXY"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"/>

            <!-- TITLE -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quên mật khẩu"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#1F2A44"
                android:gravity="center"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nhập tên tài khoản để khôi phục mật khẩu"
                android:textSize="14sp"
                android:textColor="#6C7A92"
                android:gravity="center"
                android:layout_marginBottom="40dp"/>

            <!-- USERNAME -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên tài khoản"
                android:textSize="13sp"
                android:textColor="#4A4A4A"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="#FFFFFF"
                android:padding="15dp"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/user_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nhập tên tài khoản"
                    android:background="@null"
                    android:textSize="15sp"/>
            </LinearLayout>

            <!-- PASSWORD -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mật khẩu mới"
                android:textSize="13sp"
                android:textColor="#4A4A4A"
                android:layout_marginTop="25dp"
                android:layout_marginBottom="10dp"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="50dp">

                <EditText
                    android:id="@+id/user_new_password"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#FFFFFF"
                    android:padding="15dp"
                    android:paddingEnd="45dp"
                    android:hint="Nhập mật khẩu mới"
                    android:inputType="textPassword"
                    android:textSize="15sp"/>

                <ImageView
                    android:id="@+id/toggle_new_password"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/hidepass"/>
            </RelativeLayout>

            <!-- CONFIRM PASSWORD -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xác nhận mật khẩu mới"
                android:textSize="13sp"
                android:textColor="#4A4A4A"
                android:layout_marginTop="25dp"
                android:layout_marginBottom="10dp"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="50dp">

                <EditText
                    android:id="@+id/confirm_user_new_password"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#FFFFFF"
                    android:padding="15dp"
                    android:paddingEnd="45dp"
                    android:hint="Xác nhận lại mật khẩu"
                    android:inputType="textPassword"
                    android:textSize="15sp"/>

                <ImageView
                    android:id="@+id/toggle_confirm_password"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/hidepass"/>
            </RelativeLayout>

            <!-- EMAIL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nhập Email để xác nhận"
                android:textSize="13sp"
                android:textColor="#4A4A4A"
                android:layout_marginTop="25dp"
                android:layout_marginBottom="10dp"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="50dp">

                <EditText
                    android:id="@+id/email_user"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#FFFFFF"
                    android:padding="15dp"
                    android:paddingEnd="45dp"
                    android:hint="Email"
                    android:inputType="textEmailAddress"
                    android:textSize="15sp"/>

            </RelativeLayout>

            <!-- NOTE -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Username phải có chữ\n• Password ≥ 8 ký tự\n• Có chữ hoa + ký tự đặc biệt\n• Email phải là @gmail.com"
                android:textColor="#6C7A92"
                android:textSize="12sp"
                android:layout_marginTop="12dp"/>

            <!-- BUTTON -->
            <LinearLayout
                android:id="@+id/btn_send"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:background="@drawable/button_start"
                android:gravity="center"
                android:layout_marginTop="30dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gửi yêu cầu"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="16sp"/>
            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>